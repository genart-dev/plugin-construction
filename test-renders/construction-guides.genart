  "id": "construction-guides",
  "title": "Construction Guides Gallery",
  "created": "2026-03-06T00:00:00Z",
  "modified": "2026-03-06T00:00:00Z",
  "renderer": { "type": "canvas2d" },
  "canvas": { "width": 1560, "height": 1520 },
  "parameters": [],
  "colors": [],
  "state": { "seed": 1, "params": {}, "colorPalette": [] },
  "algorithm": "function sketch(ctx, state) {\n  const W = 1560, H = 1520, CW = 380, CH = 340, PAD = 8, LABEL_H = 30, COLS = 4, ROWS = 4;\n  ctx.fillStyle = '#0d0d1a';\n  ctx.fillRect(0, 0, W, H);\n  for (let idx = 0; idx < 16; idx++) {\n    const col = idx % COLS;\n    const row = Math.floor(idx / COLS);\n    const x = PAD + col * (CW + PAD);\n    const y = PAD + row * (CH + LABEL_H + PAD);\n    const bx = x;\n    const by = y + LABEL_H;\n    ctx.fillStyle = '#1a1a2e';\n    ctx.fillRect(bx, by, CW, CH);\n    ctx.strokeStyle = '#333344';\n    ctx.lineWidth = 0.5;\n    ctx.strokeRect(bx + 0.5, by + 0.5, CW - 1, CH - 1);\n  }\n  return {};\n}",
